# Copie este arquivo para .env e preencha com as suas chaves gratuitas.
# O .env nunca é versionado, ele está no .gitignore. O repositório jamais contém uma chave.

# Google AI Studio (Gemini), free tier com suporte a imagem.
# Obtenha em https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq, inferência rápida e gratuita de modelos abertos, principalmente de texto.
# Obtenha em https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter, modelos variados, alguns com variante gratuita e alguns multimodais.
# Obtenha em https://openrouter.ai/keys
OPENROUTER_API_KEY=
